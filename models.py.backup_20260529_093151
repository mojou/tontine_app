# TABLE TRANSACTION - Toutes les entrées/sorties d'argent
# ============================================================
    user = db.relationship('User', backref='member', uselist=False, foreign_keys='User.member_id')
class Transaction(db.Model):
    __tablename__ = 'transactions'
    
    id = db.Column(db.Integer, primary_key=True)
    
    # Clé étrangère et relation vers le Membre
    member_id = db.Column(db.Integer, db.ForeignKey('members.id'), nullable=False)
    member = db.relationship('Member', backref='transaction_member', foreign_keys=[member_id])
    
    type = db.Column(db.String(20), nullable=False)
    amount = db.Column(db.Numeric(10, 2), nullable=False)
    description = db.Column(db.String(200))
    payment_mode = db.Column(db.String(20), default='ESPECE')
    
    # CORRECTION : Utilisation de db.func.current_date pour éviter la date figée au démarrage
    date = db.Column(db.Date, nullable=False, default=db.func.current_date)
    
    # Traçabilité des utilisateurs (Créateurs et Validateurs)
    created_by = db.Column(db.Integer, db.ForeignKey('users.id'))
    created_at = db.Column(db.DateTime, default=datetime.utcnow) # CORRECTION : datetime.utcnow sans parenthèses
    
    # CORRECTION PERFORMANCE : Relations explicites pour éviter les requêtes SQL répétitives (.query.get)
    creator = db.relationship('User', foreign_keys=[created_by], backref='transactions_created')
    
    # Suivi des cotisations
    week_number = db.Column(db.Integer, nullable=True)
    fortnight_number = db.Column(db.Integer, nullable=True)
    year = db.Column(db.Integer, nullable=True)
    is_penalty_applied = db.Column(db.Boolean, default=False)
    
    validated_by = db.Column(db.Integer, db.ForeignKey('users.id'), nullable=True)
    validation_date = db.Column(db.DateTime, nullable=True)
    validator = db.relationship('User', foreign_keys=[validated_by], backref='transactions_validated')
    
    @property
    def member_name(self):
        return self.member.full_name if self.member else "N/A"
    
    @property
    def creator_name(self):
        # OPTIMISÉ : Utilise la relation chargée en mémoire plutôt que de refaire un appel SQL .query.get()
        return self.creator.username if self.creator else "Système"
    
    @property
    def validator_name(self):
        return self.validator.username if self.validator else "N/A"
    
    def get_type_display(self):
        types = {
            'TONTINE': 'Tontine / Épargne',
            'PRESENCE': 'Cotisation Présence',
            'SANCTION': 'Sanction / Pénalité',
            'REMBOURSEMENT': 'Remboursement d\'emprunt',
            'AIDE': 'Aide Sociale',
            'FONDS_CAISSE': 'Fonds de Caisse',
            'SORTIE_LOAN': 'Décaissement d\'emprunt',
            'BENEFICE_TONTINE': 'Bénéfice Tontine'
        }
        return types.get(self.type, self.type)
    
    @staticmethod
    def get_week_number(date_obj):
        if not date_obj:
            return None
        return date_obj.isocalendar()[1]
    
    @staticmethod
    def get_fortnight_number(date_obj):
        """
        Vérification de la logique de quinzaine :
        - Du 1er au 15 du mois : Quinzaine 1
        - Du 16 au 31 du mois : Quinzaine 2
        """
        if not date_obj:
            return None
        return 1 if date_obj.day <= 15 else 2


