class ContributionPlanning(db.Model):
    __tablename__ = 'contribution_planning'
    
    id = db.Column(db.Integer, primary_key=True)
    member_id = db.Column(db.Integer, db.ForeignKey('members.id'), nullable=False)
    year = db.Column(db.Integer, nullable=False)
    month = db.Column(db.Integer, nullable=False)
    week_number = db.Column(db.Integer, nullable=True)
    contribution_type = db.Column(db.String(20), nullable=False)
    expected_amount = db.Column(db.Numeric(10, 2), nullable=False)
    expected_date = db.Column(db.Date, nullable=False)
    is_paid = db.Column(db.Boolean, default=False)
    transaction_id = db.Column(db.Integer, db.ForeignKey('transactions.id'), nullable=True)
    
    member = db.relationship('Member', backref='contributions_planning')
    
    @classmethod
    def generate_monthly_planning(cls, member_id, year, month):
        from calendar import monthrange
        import datetime
        
        _, last_day = monthrange(year, month)
        plannings = []
        member = Member.query.get(member_id)
        
        if not member:
            return []
        
        for week in range(1, 5):
            day = 1 + (week - 1) * 7
            if day <= last_day:
                date_obj = datetime.date(year, month, day)
                plannings.append({
                    'type': 'PRESENCE',
                    'amount': Decimal('1050.00'),
                    'date': date_obj,
                    'week': week
                })
        
        tontine_amount = member.chosen_tontine_amount or Decimal('10200.00')
        
        plannings.append({
            'type': 'TONTINE',
            'amount': tontine_amount,
            'date': datetime.date(year, month, 1),
            'fortnight': 1
        })
        
        second_date = 16
        if second_date <= last_day:
            plannings.append({
                'type': 'TONTINE',
                'amount': tontine_amount,
                'date': datetime.date(year, month, second_date),
                'fortnight': 2
            })
        
        return plannings


