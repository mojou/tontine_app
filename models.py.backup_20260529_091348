# ============================================================
# TABLE LOAN - Gestion des emprunts
# ============================================================
class Loan(db.Model):
    __tablename__ = 'loans'
    
    id = db.Column(db.Integer, primary_key=True)
    member_id = db.Column(db.Integer, db.ForeignKey('members.id'), nullable=False)
    amount = db.Column(db.Numeric(10, 2), nullable=False)
    interest = db.Column(db.Numeric(10, 2), nullable=False)
    total_to_pay = db.Column(db.Numeric(10, 2), nullable=False)
    amount_paid = db.Column(db.Numeric(10, 2), default=Decimal('0.00'))
    remaining_balance = db.Column(db.Numeric(10, 2), default=Decimal('0.00'))
    start_date = db.Column(db.Date, nullable=False)
    end_date = db.Column(db.Date, nullable=False)
    status = db.Column(db.String(20), default='PENDING')
    purpose = db.Column(db.String(200))
    requested_by = db.Column(db.Integer, db.ForeignKey('users.id'))
    approved_by = db.Column(db.Integer, db.ForeignKey('users.id'), nullable=True)
    approved_at = db.Column(db.DateTime, nullable=True)
    paid_at = db.Column(db.DateTime, nullable=True)
    penalty_amount = db.Column(db.Numeric(10, 2), default=Decimal('0.00'))
    penalty_applied = db.Column(db.Boolean, default=False)
    days_overdue = db.Column(db.Integer, default=0)
    application_date = db.Column(db.Date, default=datetime.utcnow().date)
    rejection_reason = db.Column(db.Text, nullable=True)
    interest_rate_applied = db.Column(db.Numeric(5, 2), default=Decimal('5.00'))
    
    @property
    def member_name(self):
        return self.member.full_name if self.member else "N/A"
    
    @property
    def remaining_to_pay(self):
        return Decimal(self.total_to_pay) + Decimal(self.penalty_amount) - Decimal(self.amount_paid)
    
    @property
    def is_overdue(self):
        return self.status == 'ACTIF' and date.today() > self.end_date

    def calculate_totals(self):
        self.total_to_pay = Decimal(self.amount) + Decimal(self.interest)
        self.remaining_balance = self.total_to_pay

    def calculate_interest_rate(self):
        if self.status == 'COMPLETED' and self.paid_at:
            days_to_repay = (self.paid_at.date() - self.start_date).days
            return Decimal('3.00') if days_to_repay <= 90 else Decimal('5.00')
        elif self.is_overdue:
            return Decimal('8.00')
        else:
            return Decimal('5.00')
    
    def apply_interest_rate(self):
        self.interest_rate_applied = self.calculate_interest_rate()
        self.interest = self.amount * (self.interest_rate_applied / 100)
        self.calculate_totals()

    def approve_and_disburse(self, operator_user_id):
        if self.status != 'PENDING':
            return False, "Cet emprunt n'est pas en attente."
        
        self.apply_interest_rate()
        self.status = 'ACTIF'
        self.approved_by = operator_user_id
        self.approved_at = datetime.utcnow()
        self.paid_at = datetime.utcnow()

        sortie_caisse = Transaction(
            member_id=self.member_id,
            type='SORTIE_LOAN',
            amount=self.amount,
            description=f"Décaissement emprunt #{self.id} - {self.purpose}",
            created_by=operator_user_id
        )
        db.session.add(sortie_caisse)
        return True, "Emprunt validé et décaissé."

    def register_payment(self, payment_amount, operator_user_id):
        amount_dec = Decimal(str(payment_amount))
        self.amount_paid += amount_dec
        self.remaining_balance = self.remaining_to_pay

        if self.remaining_balance <= 0:
            self.remaining_balance = Decimal('0.00')
            self.status = 'COMPLETED'

        encaissement = Transaction(
            member_id=self.member_id,
            type='REMBOURSEMENT',
            amount=amount_dec,
            description=f"Remboursement emprunt #{self.id}",
            created_by=operator_user_id
        )
        db.session.add(encaissement)

    def check_and_apply_penalties(self, penalty_rate_per_day=500):
        if self.is_overdue:
            overdue_days = (date.today() - self.end_date).days
            self.days_overdue = overdue_days
            self.penalty_amount = Decimal(overdue_days * penalty_rate_per_day)
            self.remaining_balance = self.remaining_to_pay
            self.penalty_applied = True

    @property
    def total_active_debt(self):
                """
                Calcule dynamiquement la dette réelle du membre.
                Prend en compte : Capital + Intérêts + Pénalités - Montants déjà payés.
                """
                # On ne filtre pas seulement par statut 'ACTIF', car un prêt 'ACTIF' en retard 
                # reste une dette tant qu'il n'est pas entièrement remboursé (statut 'COMPLETED')
                debt = sum(loan.remaining_to_pay for loan in self.loans if loan.status in ['ACTIF', 'OVERDUE'])
                return debt


